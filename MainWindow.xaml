<Window x:Class="WinKitty.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="150"
        Height="150"
        WindowStartupLocation="Manual"
        Left="500"
        Top="300">
    <Canvas>
        <Ellipse Width="100"
                 Height="100"
                 Fill="Orange"
                 Stroke="Black"
                 StrokeThickness="2"/>
    </Canvas>
</Window>
