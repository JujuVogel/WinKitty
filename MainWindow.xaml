<Window x:Class="WinKitty.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="150"
        Height="150"
        WindowStartupLocation="Manual"
        Left="500"
        Top="300">
    <Canvas>
        <Image x:Name="Idle"
               Source="assets/cat_animations/Idle.png"
               Width="64"
               Height="32"
               Stretch="Uniform"/>
    </Canvas>
</Window>
