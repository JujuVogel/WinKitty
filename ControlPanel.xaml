<Window x:Class="WinKitty.ControlPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinKitty - Panneau de contrôle"
        Width="300"
        Height="400">
        <StackPanel Margin="10">
                <TextBox x:Name="CatNameBox"
                         Text="Nom du chat"
                         Margin="0,0,0,10"/>
                <Button Content="Nourrir"
                        Click="OnFeed"
                        Margin="0,0,0,5"/>
                <Button Content="Dormir"
                        Click="OnSleep"
                        Margin="0,0,0,5"/>
                <Button Content="Jouer"
                        Click="OnPlay"
                        Margin="0,0,0,5"/>
                <Button Content="Toilettes"
                        Click="OnClean"
                        Margin="0,0,0,5"/>
        </StackPanel>
</Window>
